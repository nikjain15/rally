# Rally — production environment (set these in the Vercel project, NOT committed with real values).
# Local dev needs NONE of these — `npm run explore` uses the Firebase emulator.
# Copy to .env.local for a real-Firebase local run, or paste into Vercel → Settings → Environment Variables.

# --- Firebase client config (from Firebase console → Project settings → your web app) ---
# These are public by design (they ship to the browser) — safe to expose, gated by firestore.rules.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=          # e.g. rally-nikjain15.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=           # e.g. rally-nikjain15
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase admin (server routes that write XP/pulse/commitments) ---
# The FULL service-account JSON as a single line (Firebase console → Project settings →
# Service accounts → Generate new private key). SECRET — never NEXT_PUBLIC_, never commit.
FIREBASE_SERVICE_ACCOUNT=

# --- AI (the three intelligences; app runs without it, they just degrade to no-op) ---
ANTHROPIC_API_KEY=

# --- GitHub PM integration (optional; commitments work without it, just unlinked) ---
GITHUB_TOKEN=                              # repo scope, for creating issues
GITHUB_PM_REPO=                            # e.g. nikjain15/rally-tasks
GITHUB_WEBHOOK_SECRET=                     # for verifying issue-closed webhooks
